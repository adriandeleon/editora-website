---
import Layout from "../layouts/Layout.astro";
import { version, repo, latestRelease } from "../lib/editora";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}/${p}`.replace(/\/{2,}/g, "/");
const logo = url("editora-icon.svg");

const features = [
  {
    title: "Command-driven core",
    body: "Every action is a registered <code>Command</code> — bind it to a chord or run it from the M-x command palette. Nothing is buried in a menu.",
  },
  {
    title: "Emacs-style keymap",
    body: "Multi-key chord sequences like <kbd>C-x C-s</kbd>, with user overrides. Keyboard-first, mouse-optional.",
  },
  {
    title: "Jump-to popups",
    body: "Fuzzy pickers for recent files, file structure/symbols, open tabs, and tool windows — plus an Emacs <code>find-file</code>-style path finder.",
  },
  {
    title: "Syntax highlighting",
    body: "TextMate grammars (via tm4e) for 21 languages: Java, Python, Rust, Go, Kotlin, C/C++, C#, Ruby, SQL, Markdown, and more.",
  },
  {
    title: "Markdown preview",
    body: "IntelliJ-style 3-mode view (Editor / Split / Preview), rendered natively with CommonMark + GFM, live-updating and theme-matched.",
  },
  {
    title: "Projects",
    body: "VSCode single-folder workspaces: a root folder plus its own saved session (open files, layout, folds), shown as a filterable file tree.",
  },
  {
    title: "Bookmarks",
    body: "Line bookmarks with gutter markers and notes, a cross-file jump picker, and a tool window listing them across every file.",
  },
  {
    title: "Themes & fonts",
    body: "Switchable themes (Primer, Nord, Cupertino, Dracula) with matching editor color themes, and five bundled monospace fonts — no install needed.",
  },
  {
    title: "Read-only / View mode",
    body: "Toggle a buffer read-only to browse without editing; pager-style <kbd>Space</kbd>/<kbd>Backspace</kbd> paging and a Word-style View Mode banner.",
  },
  {
    title: "Built for speed",
    body: "Off-thread tokenizing, debounced highlighting, and incremental, visible-only overlays keep the UI responsive even on large files.",
  },
];

const platforms = [
  { name: "macOS", note: "DMG installer (x64 / arm64)" },
  { name: "Windows", note: "MSI installer (x64)" },
  { name: "Linux", note: "DEB installer (x64 / arm64)" },
];
---

<Layout>
  <section class="hero">
    <div class="hero-inner">
      <img class="hero-logo" src={logo} alt="Editora logo" width="96" height="96" />
      <h1>A keyboard-driven programmer's text editor</h1>
      <p class="tagline">
        Fast, cross-platform, and command-first. Built with JDK&nbsp;25 and
        JavaFX&nbsp;25. Every action is a command — reachable by an Emacs-style
        keymap or a fuzzy palette.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="#download">Download</a>
        <a class="btn btn-ghost" href={url("keybindings")}>Keybindings</a>
      </div>
    </div>
  </section>

  <main>
    <section id="features" class="section">
      <h2>Features</h2>
      <div class="grid">
        {
          features.map((f) => (
            <article class="card">
              <h3>{f.title}</h3>
              <p set:html={f.body} />
            </article>
          ))
        }
      </div>
    </section>

    <section id="download" class="section">
      <h2>Download</h2>
      <p class="section-lead">
        Native installers and self-contained runnable jars for every platform
        are attached to each release.
      </p>
      <div class="platforms">
        {
          platforms.map((p) => (
            <div class="platform">
              <strong>{p.name}</strong>
              <span>{p.note}</span>
            </div>
          ))
        }
      </div>
      <div class="cta">
        <a class="btn btn-primary" href={latestRelease}>Latest release (v{version})</a>
        <a class="btn btn-ghost" href={`${repo}/releases`}>All releases</a>
      </div>
      <p class="note">
        Installers are currently unsigned. On macOS, right-click the app and
        choose <em>Open</em> the first time.
      </p>
    </section>

    <section id="quickstart" class="section">
      <h2>Build &amp; run from source</h2>
      <p class="section-lead">
        Requires JDK&nbsp;25+. A Maven wrapper is bundled, so no local Maven
        install is needed.
      </p>
      <div class="code-window">
        <div class="code-chrome">
          <span class="dot"></span><span class="dot"></span><span class="dot"
          ></span>
          <span class="code-title">terminal</span>
        </div>
        <pre><code><span class="tok-comment"># Clone</span>
<span class="tok-keyword">git</span> clone {repo}.git
<span class="tok-keyword">cd</span> Editora

<span class="tok-comment"># Run the app</span>
./mvnw javafx:run

<span class="tok-comment"># Build a native installer (DMG / MSI / DEB)</span>
./mvnw <span class="tok-flag">-Pdist</span> package

<span class="tok-comment"># Build a self-contained runnable jar</span>
./mvnw <span class="tok-flag">-Pfatjar</span> package
<span class="tok-keyword">java</span> <span class="tok-flag">-jar</span> target/Editora-{version}.jar</code></pre>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    background:
      radial-gradient(
        1200px 600px at 50% -20%,
        rgba(88, 166, 255, 0.14),
        transparent 60%
      ),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.25rem 5rem;
    text-align: center;
  }

  .hero-logo {
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--muted);
    margin: 0 auto 2rem;
    max-width: 38rem;
  }

  .cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    border: 1px solid transparent;
    transition: transform 0.05s ease, background 0.15s ease;
  }

  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: #06101f;
  }

  .btn-ghost {
    border-color: var(--border);
    color: var(--text);
    background: var(--bg-soft);
  }

  main {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .section:last-child {
    border-bottom: none;
  }

  h2 {
    font-size: 1.9rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .section-lead {
    color: var(--muted);
    margin: 0 0 2rem;
    max-width: 42rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }

  .card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
  }

  .card p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .platforms {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .platform {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .platform strong {
    font-size: 1.1rem;
  }

  .platform span {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .note {
    color: var(--muted);
    font-size: 0.875rem;
    margin-top: 1.25rem;
  }

  .code-window {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-soft);
  }

  .code-chrome {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border-soft);
  }

  .code-chrome .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--faint);
    opacity: 0.5;
  }

  .code-chrome .dot:nth-child(1) {
    background: #ff7b72;
    opacity: 0.8;
  }
  .code-chrome .dot:nth-child(2) {
    background: var(--bookmark);
    opacity: 0.8;
  }
  .code-chrome .dot:nth-child(3) {
    background: #7ee787;
    opacity: 0.8;
  }

  .code-chrome .code-title {
    margin-left: 0.5rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--faint);
  }

  pre {
    margin: 0;
    padding: 1.25rem;
    overflow-x: auto;
    line-height: 1.7;
  }

  pre code {
    font-size: 0.85rem;
    color: var(--text);
  }
</style>
