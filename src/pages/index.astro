---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { version, repo } from "../lib/editora";
import { whatsNew } from "../lib/whatsnew";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}/${p}`.replace(/\/{2,}/g, "/");
const logo = url("editora-icon.svg");
const changelogUrl = `${repo}/blob/master/CHANGELOG.md`;

// Latest entries for the home-page teaser — News first, then Blog.
const byDate = (a, b) => b.data.date.valueOf() - a.data.date.valueOf();
const newsItems = (await getCollection("news")).sort(byDate).map((e) => ({
  kind: "News",
  href: `/news/${e.id}`,
  title: e.data.title,
  description: e.data.description,
  date: e.data.date,
}));
const blogItems = (await getCollection("blog")).sort(byDate).map((e) => ({
  kind: "Blog",
  href: `/blog/${e.id}`,
  title: e.data.title,
  description: e.data.description,
  date: e.data.date,
}));
const latest = [...newsItems, ...blogItems].slice(0, 4);
const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });

const featureGroups = [
  {
    title: "Keyboard & commands",
    cards: [
      {
        title: "Command-driven core",
        body: "Hunting through menus? Every action is a registered <code>Command</code> — bound to a chord or one <kbd>M-x</kbd> search away. 200+ commands, nothing buried.",
      },
      {
        title: "Emacs-style keymap",
        body: "Multi-key chord sequences like <kbd>C-x C-s</kbd>, with user overrides. Keyboard-first, mouse-optional.",
      },
      {
        title: "Jump-to popups",
        body: "Lost in a big project? Fuzzy-jump to recent files, symbols, open tabs, and tool windows — plus an Emacs <code>find-file</code>-style path finder.",
      },
      {
        title: "Multiple cursors",
        body: "Add a caret at the next occurrence or above/below, or <kbd>Alt</kbd>-drag a column/box selection — edit many places at once, VS Code-style.",
      },
    ],
  },
  {
    title: "Editing",
    cards: [
      {
        title: "Snippets",
        body: "Retyping the same boilerplate? Expand VS Code / TextMate templates with tab stops, mirrors, choices, and variables — a prefix + <kbd>Tab</kbd>. Ships for all 21 languages.",
      },
      {
        title: "Smart indentation",
        body: "Per-language auto-indent on <kbd>Enter</kbd> (block openers, matching-pair stanzas, closer re-alignment), plus smart backspace that clears a whole indent level in one press.",
      },
      {
        title: "Auto-close & bracket matching",
        body: "Typing <code>([{</code> or quotes inserts the closer, type-over to skip, wrap a selection, and Backspace clears an empty pair — and the bracket beside the caret is highlighted with its match.",
      },
      {
        title: "Comment toggling",
        body: "<kbd>M-;</kbd> comments or uncomments the line or selection using the language's syntax (<code>//</code>, <code>#</code>, <code>&lt;!-- --&gt;</code>, <code>/* */</code>, <code>--</code>, …).",
      },
      {
        title: "Spell checking",
        body: "Red wavy underlines with right-click suggestions, Add-to-Dictionary, and Ignore — full text for prose, comments & strings for code. Pure-Java Hunspell; English, Spanish, French.",
      },
    ],
  },
  {
    title: "Code intelligence",
    cards: [
      {
        title: "Syntax highlighting",
        body: "TextMate grammars (via tm4e) for 21 languages: Java, Python, Rust, Go, Kotlin, C/C++, C#, Ruby, SQL, Markdown, and more.",
      },
      {
        title: "Language servers (LSP)",
        body: "Go-to-definition, find references, hover docs, diagnostics, and completions via 20+ language servers (Java, TypeScript, Python, Go, Rust, C/C++, and more) — auto-detected, never bundled.",
      },
      {
        title: "Autocomplete",
        body: "As-you-type completion — a popup for code (LSP + snippets) and inline ghost text for prose. Trigger with <kbd>C-M-i</kbd> / <kbd>M-/</kbd>.",
      },
    ],
  },
  {
    title: "Run & debug",
    cards: [
      {
        title: "Run files",
        body: "Run a Java compact source file, Python, or shell script from a gutter ▶ — output and <code>stdin</code> in the Run console, with clickable stack traces and per-file arguments.",
      },
      {
        title: "Debugging (DAP)",
        body: "Full debugging for Java, Python, and JavaScript: breakpoints, step in/over/out, watches, set-value, run-to-cursor, inline values, and an interactive console.",
      },
      {
        title: "HTTP client",
        body: "Run <code>.http</code> / <code>.rest</code> requests from a gutter ▶ — environments, variables, and a formatted response view. Built on the JDK HTTP client.",
      },
    ],
  },
  {
    title: "Git & diff",
    cards: [
      {
        title: "Git integration",
        body: "Native Git: branch + ahead/behind in the status bar, gutter change bars vs HEAD, a Commit tool window (stage / unstage / discard / commit), and fetch / pull / push + branch switching.",
      },
      {
        title: "Diff & merge",
        body: "Side-by-side and unified diff (vs HEAD, a commit, or another file) with word-level highlights and apply-hunk arrows — plus a merge-conflict resolver.",
      },
    ],
  },
  {
    title: "Docs & diagrams",
    cards: [
      {
        title: "Markdown preview",
        body: "IntelliJ-style 3-mode view (Editor / Split / Preview), rendered natively with CommonMark + GFM. GitHub-style output: task-list checkboxes, code pills, and local/remote images. Live and theme-matched.",
      },
      {
        title: "Mermaid diagrams",
        body: "Render Mermaid diagrams inline in Markdown and in standalone <code>.mmd</code> files, with live linting and export to SVG / PNG / PDF.",
      },
      {
        title: "Export to PDF & print",
        body: "Export code or the Markdown preview to a syntax-highlighted PDF, or print with a preview — light-themed and generated off-thread.",
      },
    ],
  },
  {
    title: "Workspace & files",
    cards: [
      {
        title: "Projects",
        body: "VS Code single-folder workspaces: a root folder plus its own saved session (open files, layout, folds), shown as a filterable file tree.",
      },
      {
        title: "Bookmarks & notes",
        body: "Line bookmarks (gutter markers, cross-file jump, per-project), plus Personal Notes attached to a word/line/range — stored outside the file, surviving renames, with Markdown bodies.",
      },
      {
        title: "Find in files",
        body: "Project-wide search and replace with a results panel, plus AceJump to leap the caret to any visible spot by typing a label.",
      },
      {
        title: "File templates",
        body: "New File From Template — single- or multi-file scaffolds with interactive placeholders (author, date, file name, …).",
      },
      {
        title: "Read-only / View mode",
        body: "Toggle a buffer read-only to browse without editing; pager-style <kbd>Space</kbd>/<kbd>Backspace</kbd> paging and a Word-style View Mode banner.",
      },
      {
        title: "Remote files (SFTP)",
        body: "Browse, edit, search, and save files on a remote host over SSH/SFTP — the project tree, search, bookmarks, and notes all work over the wire.",
      },
    ],
  },
  {
    title: "Customization & extensibility",
    cards: [
      {
        title: "Themes & fonts",
        body: "Six editor themes (Primer, Nord, Cupertino, Dracula, Islands — light &amp; dark) that follow the app theme, plus five bundled monospace fonts — no install needed.",
      },
      {
        title: "Plugins",
        body: 'Extend the editor with commands, tool windows, and integrations — install from a built-in registry of <a href="/plugins">19 plugins</a> or write your own (Java or a simple manifest).',
      },
      {
        title: "Simple UI mode",
        body: "One toggle strips the editor to the essentials — hiding the extra toolbar groups, tool-window stripe, breadcrumb, gutter, and minimap for a calm, minimal surface.",
      },
      {
        title: "Localized UI",
        body: "The whole interface is translated — English, Italian, Spanish, French, Portuguese, and German — selectable in Settings.",
      },
    ],
  },
];

const perfStats = [
  {
    stat: "Off the UI thread",
    body: "Tokenizing, parsing, and search run in the background — the editor never blocks while you type.",
  },
  {
    stat: "Large files stay smooth",
    body: "5 MB+ skips highlighting and the minimap; 50 MB+ opens read-only with a capped load so a multi-GB log can't exhaust memory.",
  },
  {
    stat: "Incremental everything",
    body: "Edits re-tokenize only from the changed line; overlays and the gutter redraw just the visible lines, coalesced to one pass per frame.",
  },
  {
    stat: "Bounded memory",
    body: "Capped undo history and capped loads keep memory predictable, even on huge files.",
  },
];

const platforms = [
  { name: "macOS", note: "DMG installer (x64 / arm64)" },
  { name: "Windows", note: "MSI installer (x64)" },
  { name: "Linux", note: "DEB installer (x64 / arm64)" },
];
---

<Layout>
  <section class="hero">
    <div class="hero-inner">
      <img class="hero-logo" src={logo} alt="Editora logo" width="96" height="96" />
      <h1>A keyboard-driven programmer's text editor</h1>
      <p class="tagline">
        Fast, cross-platform, and command-first. Every action is a command —
        reachable by an Emacs-style keymap or a fuzzy palette.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="#download">Download</a>
        <a class="btn btn-ghost" href={url("keybindings")}>Keybindings</a>
      </div>

      <p class="hero-kbd">
        Keyboard-first — every action is a keystroke or a <kbd>M-x</kbd> search
        away.
      </p>

      <div class="badges">
        <a id="badge-stars" class="badge" href={`${repo}/stargazers`} hidden>
          <span class="badge-icon">★</span>
          <span id="badge-stars-count">—</span>
        </a>
        <a class="badge" href={`${repo}/blob/master/LICENSE`}>MIT License</a>
        <a id="badge-ci" class="badge" href={`${repo}/actions/workflows/ci.yml`} hidden>
          <span id="badge-ci-dot" class="badge-dot"></span>
          <span id="badge-ci-text">build</span>
        </a>
        <a class="badge" href={repo}>Open source on GitHub</a>
      </div>
    </div>

    <div class="hero-shot">
      <img
        src={url("screenshots/editor.jpg")}
        alt="The Editora editor: a Java file with syntax highlighting, line-number gutter with bookmarks, minimap, and status bar"
        width="2000"
        height="1541"
        fetchpriority="high"
      />
    </div>
  </section>

  <main>
    <section id="why" class="section why">
      <h2>Why Editora</h2>
      <p>
        Editora is a keyboard-first editor for people who'd rather keep their
        hands on the keys. Every action is a command you can bind or
        fuzzy-search, it stays responsive on huge files, and it runs the same on
        macOS, Windows, and Linux. It's free, open source, and quiet — no
        accounts, no telemetry, no subscriptions.
      </p>
    </section>

    {
      latest.length > 0 && (
        <section id="latest" class="section">
          <div class="latest-head">
            <h2>From the blog &amp; news</h2>
            <span class="latest-links">
              <a href="/news">All news</a> · <a href="/blog">All posts</a>
            </span>
          </div>
          <div class="latest-grid">
            {latest.map((p) => (
              <a class="latest-card" href={p.href}>
                <span class={`latest-kind ${p.kind.toLowerCase()}`}>{p.kind}</span>
                <span class="latest-title">{p.title}</span>
                {p.description && <span class="latest-desc">{p.description}</span>}
                <span class="latest-date">{fmtDate(p.date)}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section id="features" class="section">
      <h2>Features</h2>
      {
        featureGroups.map((g) => (
          <div class="feature-group">
            <h3 class="feature-group-title">{g.title}</h3>
            <div class="grid">
              {g.cards.map((f) => (
                <article class="card">
                  <h4>{f.title}</h4>
                  <p set:html={f.body} />
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <section id="performance" class="section">
      <h2>Built for speed</h2>
      <p class="section-lead">
        Performance is a first-class goal — the UI thread stays free and work
        happens incrementally, off-thread, and only on what's visible.
      </p>
      <div class="perf">
        {
          perfStats.map((s) => (
            <div class="perf-item">
              <strong>{s.stat}</strong>
              <span>{s.body}</span>
            </div>
          ))
        }
      </div>
    </section>

    {
      whatsNew.length > 0 && (
        <section id="whats-new" class="section">
          <h2>What's new</h2>
          <p class="section-lead">
            Recently shipped — see the{" "}
            <a href={changelogUrl}>full changelog</a> for everything.
          </p>
          <ul class="news">
            {whatsNew.map((n) => (
              <li>
                <span class="news-title" set:html={n.title} />
                {n.detail && (
                  <span class="news-detail">
                    {" — "}
                    <span set:html={n.detail} />
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section id="download" class="section">
      <h2>Download</h2>
      <p class="section-lead">
        Native installers and self-contained runnable jars for every platform
        are attached to each release.
      </p>
      <div class="platforms">
        {
          platforms.map((p) => (
            <div class="platform">
              <strong>{p.name}</strong>
              <span>{p.note}</span>
            </div>
          ))
        }
      </div>
      <div class="cta">
        <a
          id="dl-primary"
          class="btn btn-primary"
          href={`${repo}/releases/latest`}
          data-repo={repo}
        >
          Download
        </a>
        <a class="btn btn-ghost" href={`${repo}/releases`}>All releases</a>
      </div>
      <p id="dl-sub" class="note">
        Native installer (bundles a Java runtime — nothing else to install), or a
        self-contained <code>java -jar</code> on JDK&nbsp;25.
      </p>
      <p class="note">
        Installers are currently unsigned. On macOS, right-click the app and
        choose <em>Open</em> the first time.
      </p>
    </section>

    <section id="quickstart" class="section">
      <h2>Build &amp; run from source</h2>
      <p class="section-lead">
        Requires JDK&nbsp;25+. A Maven wrapper is bundled, so no local Maven
        install is needed.
      </p>
      <div class="code-window">
        <div class="code-chrome">
          <span class="dot"></span><span class="dot"></span><span class="dot"
          ></span>
          <span class="code-title">terminal</span>
        </div>
        <pre><code><span class="tok-comment"># Clone</span>
<span class="tok-keyword">git</span> clone {repo}.git
<span class="tok-keyword">cd</span> Editora

<span class="tok-comment"># Run the app</span>
./mvnw javafx:run

<span class="tok-comment"># Build a native installer (DMG / MSI / DEB)</span>
./mvnw <span class="tok-flag">-Pdist</span> package

<span class="tok-comment"># Build a self-contained runnable jar</span>
./mvnw <span class="tok-flag">-Pfatjar</span> package
<span class="tok-keyword">java</span> <span class="tok-flag">-jar</span> target/Editora-{version}.jar</code></pre>
      </div>
    </section>
  </main>

  <script is:inline define:vars={{ repo }}>
    (function () {
      var api = repo.replace("https://github.com/", "https://api.github.com/repos/");

      // --- OS-detected download ---
      (function () {
        var btn = document.getElementById("dl-primary");
        if (!btn) return;
        var ua = navigator.userAgent;
        var os = "Linux",
          exts = [".deb", ".appimage", ".rpm", ".tar.gz"];
        if (/Mac/i.test(ua)) {
          os = "macOS";
          exts = [".dmg", ".pkg"];
        } else if (/Win/i.test(ua)) {
          os = "Windows";
          exts = [".msi", ".exe"];
        }
        btn.textContent = "Download for " + os;
        // Try to deep-link the matching asset from the latest release.
        fetch(api + "/releases/latest")
          .then(function (r) {
            return r.ok ? r.json() : null;
          })
          .then(function (rel) {
            if (!rel || !rel.assets) return;
            var pick = null;
            for (var e = 0; e < exts.length && !pick; e++) {
              for (var i = 0; i < rel.assets.length; i++) {
                if (rel.assets[i].name.toLowerCase().endsWith(exts[e])) {
                  pick = rel.assets[i];
                  break;
                }
              }
            }
            if (pick) {
              btn.href = pick.browser_download_url;
              var sub = document.getElementById("dl-sub");
              if (sub && rel.tag_name)
                btn.textContent = "Download for " + os + " (" + rel.tag_name + ")";
            }
          })
          .catch(function () {});
      })();

      // --- GitHub stars ---
      fetch(api)
        .then(function (r) {
          return r.ok ? r.json() : null;
        })
        .then(function (d) {
          if (!d || typeof d.stargazers_count !== "number") return;
          var el = document.getElementById("badge-stars");
          document.getElementById("badge-stars-count").textContent =
            d.stargazers_count.toLocaleString();
          el.hidden = false;
        })
        .catch(function () {});

      // --- CI status (latest run on default branch) ---
      fetch(api + "/actions/workflows/ci.yml/runs?per_page=1")
        .then(function (r) {
          return r.ok ? r.json() : null;
        })
        .then(function (d) {
          if (!d || !d.workflow_runs || !d.workflow_runs.length) return;
          var run = d.workflow_runs[0];
          var ok = run.conclusion === "success";
          var el = document.getElementById("badge-ci");
          document.getElementById("badge-ci-text").textContent = ok
            ? "build passing"
            : "build " + (run.conclusion || run.status || "unknown");
          document.getElementById("badge-ci-dot").style.background = ok
            ? "#3fb950"
            : "#d29922";
          el.hidden = false;
        })
        .catch(function () {});
    })();
  </script>
</Layout>

<style>
  .hero {
    background:
      radial-gradient(
        1200px 600px at 50% -20%,
        color-mix(in srgb, var(--accent) 16%, transparent),
        transparent 60%
      ),
      var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.25rem 2.5rem;
    text-align: center;
  }

  .hero-shot {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 1.25rem 4rem;
  }

  .hero-shot img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow:
      0 20px 50px -20px rgba(0, 0, 0, 0.6),
      0 0 0 1px var(--border-soft);
  }

  .hero-kbd {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 1.25rem 0 0;
  }

  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }

  .badge:hover {
    color: var(--text);
    border-color: var(--accent);
    text-decoration: none;
  }

  .badge-icon {
    color: var(--bookmark);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--faint);
  }

  /* What's new */
  .news {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 0.75rem 2rem;
  }

  .news li {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--border-soft);
    font-size: 0.95rem;
  }

  .news-title {
    font-weight: 600;
  }

  .news-detail {
    color: var(--muted);
  }

  /* Latest blog & news teaser */
  .latest-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .latest-links {
    font-size: 0.9rem;
    color: var(--muted);
  }
  .latest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }
  .latest-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.1rem 1.25rem;
    color: var(--text);
  }
  .latest-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .latest-kind {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--muted);
  }
  .latest-kind.news {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }
  .latest-kind.blog {
    color: var(--bookmark);
    border-color: color-mix(in srgb, var(--bookmark) 40%, transparent);
  }
  .latest-title {
    font-weight: 600;
    font-size: 1rem;
  }
  .latest-desc {
    color: var(--muted);
    font-size: 0.9rem;
  }
  .latest-date {
    color: var(--faint);
    font-size: 0.8rem;
    margin-top: auto;
  }

  .hero-logo {
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--muted);
    margin: 0 auto 2rem;
    max-width: 38rem;
  }

  .cta {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    border: 1px solid transparent;
    transition: transform 0.05s ease, background 0.15s ease;
  }

  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--accent);
    color: var(--on-accent);
  }

  .btn-ghost {
    border-color: var(--border);
    color: var(--text);
    background: var(--bg-soft);
  }

  main {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  .section {
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .section:last-child {
    border-bottom: none;
  }

  h2 {
