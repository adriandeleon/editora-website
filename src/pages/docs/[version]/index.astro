---
import { getEntry } from "astro:content";
import DocsLayout from "../../../layouts/DocsLayout.astro";
import { version } from "../../../lib/version";

// The docs landing (introduction) for the current version: /docs/v-<version>/.
export function getStaticPaths() {
  return [{ params: { version: `v-${version}` } }];
}

const entry = await getEntry("docs", "introduction");
if (!entry) throw new Error("docs/introduction.md is missing");
---

<DocsLayout entry={entry} />
