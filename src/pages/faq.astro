---
import Layout from "../layouts/Layout.astro";
import { repo } from "../lib/editora";
const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}/${p}`.replace(/\/{2,}/g, "/");

const faqs = [
  {
    q: "Is Editora free and open source?",
    a: 'Yes — it\'s free and released under the MIT License. Source is on <a href="' +
      repo +
      '">GitHub</a>.',
  },
  {
    q: "Does it phone home or collect telemetry?",
    a: "No. There are no accounts, no telemetry, and no network calls for analytics — it's a local editor.",
  },
  {
    q: "Which platforms are supported?",
    a: "macOS (Intel &amp; Apple Silicon), Windows (x64), and Linux (x64 &amp; arm64). Windows-on-ARM runs the x64 installer under emulation.",
  },
  {
    q: "Do I need Java installed?",
    a: 'No for the native installers — they bundle their own Java runtime. The portable fat jar does need JDK&nbsp;25 (<code>java -jar</code>).',
  },
  {
    q: "The installer says it's from an unidentified developer.",
    a: "Installers are currently unsigned. On macOS, right-click the app and choose <em>Open</em> the first time; on Windows, click “More info → Run anyway” in SmartScreen. Signing is on the roadmap.",
  },
  {
    q: "How do I add a language, snippet, or dictionary word?",
    a: 'Snippets: drop a <code>snippets/&lt;language&gt;.json</code> in your config folder (they override the bundled ones). Spell-check: “Add to Dictionary” saves to <code>dictionary.txt</code>; pick a language per file with “Spell Check: Set Language…”. See <a href="' +
      "CONFIGPLACEHOLDER" +
      '">Configuration</a>.',
  },
  {
    q: "Can I rebind keys or use a different keymap?",
    a: 'Yes — Editora is keyboard-first and every action is a command. User keybinding overrides layer on top of the default Emacs-style keymap in <code>settings.toml</code>. See the <a href="KBPLACEHOLDER">keybindings reference</a>.',
  },
  {
    q: "How do I run a separate, throwaway config?",
    a: "Launch with <code>--dev</code> to use an isolated <code>~/.editora-dev/</code> config, or <code>--config-dir &lt;path&gt;</code> / the <code>EDITORA_CONFIG_DIR</code> env var to point anywhere.",
  },
  {
    q: "Why JavaFX?",
    a: "It gives one native-feeling, cross-platform codebase with a fast text surface (RichTextFX), and lets Editora ship a single app per platform without a browser engine.",
  },
];

const faqsResolved = faqs.map((f) => ({
  q: f.q,
  a: f.a
    .replace("CONFIGPLACEHOLDER", url("configuration"))
    .replace("KBPLACEHOLDER", url("keybindings")),
}));
---

<Layout
  title="FAQ — Editora"
  description="Frequently asked questions about Editora: licensing, telemetry, platforms, signing, customization, and config."
>
  <main class="doc">
    <h1>FAQ</h1>
    <p class="lead">Quick answers to common questions.</p>

    {
      faqsResolved.map((f) => (
        <div class="faq-item">
          <h2>{f.q}</h2>
          <p set:html={f.a} />
        </div>
      ))
    }

    <p style="margin-top:2.5rem">
      Didn't find your answer? <a href={`${repo}/issues`}>Open an issue</a>.
    </p>
  </main>
</Layout>

<style>
  .faq-item h2 {
    font-size: 1.15rem;
  }
</style>
