---
import Layout from "../layouts/Layout.astro";
import { commandGroups } from "../lib/commands";

// Derived from the same source as the Commands page: every command that has a
// default keybinding, grouped by category. Stays in sync automatically.
const groups = commandGroups
  .map((g) => ({
    title: g.title,
    bindings: g.commands.filter((c) => c.keys),
  }))
  .filter((g) => g.bindings.length > 0);

const count = groups.reduce((n, g) => n + g.bindings.length, 0);
---

<Layout
  title="Keybindings — Editora"
  description="The full Emacs-style keymap for Editora — every command with a default keybinding, grouped by area."
>
  <main class="page">
    <h1>Keybindings</h1>
    <p class="lead">
      Editora ships an Emacs-style keymap — {count} commands have a default
      binding. Every binding maps to a <strong>command</strong>, so the same
      actions are reachable from the <kbd>M-x</kbd> palette (see the full
      <a href="/commands">command list</a>) and can be rebound in Settings.
    </p>

    <div class="legend">
      <span><kbd>C-</kbd> Control</span>
      <span><kbd>M-</kbd> Alt / Option (Meta)</span>
      <span><kbd>S-</kbd> Shift</span>
      <span>Space-separated = a chord sequence, e.g. <kbd>C-x</kbd> then <kbd
          >C-s</kbd
        ></span>
    </div>

    <div class="columns">
      {
        groups.map((g) => (
          <section class="group">
            <h2>{g.title}</h2>
            <table>
              <tbody>
                {g.bindings.map((b) => (
                  <tr>
                    <td class="keys">
                      {b.keys.split(" ").map((tok) => (
                        <kbd>{tok}</kbd>
                      ))}
                    </td>
                    <td class="desc">{b.title}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </section>
        ))
      }
    </div>

    <p class="note">
      <strong>macOS note:</strong> the Option dead keys
      (<kbd>Option</kbd>+<kbd>e</kbd>/<kbd>i</kbd>/<kbd>u</kbd>/<kbd>n</kbd>/<kbd
        >`</kbd
      >) are intercepted by the OS for accent composition, so a few
      <kbd>M-</kbd> chords like <kbd>M-e</kbd> aren't reachable by keyboard
      there — the command palette still works.
    </p>
  </main>
</Layout>

<style>
  .page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 3rem 1.25rem 2rem;
  }

  h1 {
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .lead {
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 1.5rem;
  }

  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: 1rem 1.25rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 2.5rem;
  }

  .columns {
    columns: 2;
    column-gap: 2rem;
  }

  .group {
    break-inside: avoid;
    margin-bottom: 2rem;
  }

  .group h2 {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  td {
    padding: 0.3rem 0;
    vertical-align: top;
  }

  td.keys {
    white-space: nowrap;
    padding-right: 1rem;
    width: 1%;
  }

  td.keys kbd + kbd {
    margin-left: 0.25rem;
  }

  td.desc {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .note {
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    color: var(--text);
  }

  @media (max-width: 720px) {
    .columns {
      columns: 1;
    }
  }
</style>
