---
import Layout from "../layouts/Layout.astro";
import { readdirSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, resolve, parse } from "node:path";
import { repo } from "../lib/editora";

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}/${p}`.replace(/\/{2,}/g, "/");

// Optional captions keyed by filename. Anything not listed gets a caption
// derived from its filename. Drop images into public/screenshots/ and they
// appear here automatically.
const captions: Record<string, string> = {
  // "editor.png": "The editor with syntax highlighting and the gutter",
};

const here = dirname(fileURLToPath(import.meta.url));
const dir = resolve(here, "../../public/screenshots");
const exts = new Set([".png", ".jpg", ".jpeg", ".gif", ".webp", ".avif"]);

const prettify = (name: string) =>
  name
    .replace(/[-_]+/g, " ")
    .replace(/\b\w/g, (c) => c.toUpperCase())
    .trim();

let shots: { src: string; alt: string; caption: string }[] = [];
try {
  shots = readdirSync(dir)
    .filter((f) => exts.has(parse(f).ext.toLowerCase()))
    .sort()
    .map((f) => {
      const caption = captions[f] ?? prettify(parse(f).name);
      return { src: url(`screenshots/${f}`), alt: caption, caption };
    });
} catch {
  shots = [];
}
---

<Layout
  title="Screenshots — Editora"
  description="Screenshots of Editora: the editor, command palette, tool windows, themes, and Markdown preview."
>
  <main class="page">
    <h1>Screenshots</h1>
    <p class="lead">
      A look at Editora in action — the editor surface, command palette, tool
      windows, themes, and Markdown preview.
    </p>

    {
      shots.length > 0 ? (
        <div class="gallery">
          {shots.map((s) => (
            <figure class="shot">
              <a href={s.src} target="_blank" rel="noopener">
                <img src={s.src} alt={s.alt} loading="lazy" />
              </a>
              <figcaption>{s.caption}</figcaption>
            </figure>
          ))}
        </div>
      ) : (
        <div class="empty">
          <p>No screenshots yet.</p>
          <p class="empty-hint">
            Drop image files into <code>website/public/screenshots/</code> and
            they'll appear here automatically — the filename becomes the
            caption (e.g. <code>command-palette.png</code> →
            "Command Palette"). Add custom captions in the
            <code>captions</code> map at the top of
            <code>src/pages/screenshots.astro</code>.
          </p>
          <p>
            <a href={repo}>See the project on GitHub</a> in the meantime.
          </p>
        </div>
      )
    }
  </main>
</Layout>

<style>
  .page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 3rem 1.25rem 2rem;
  }

  h1 {
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .lead {
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 2.5rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .shot {
    margin: 0;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .shot img {
    display: block;
    width: 100%;
    height: auto;
    border-bottom: 1px solid var(--border);
  }

  .shot figcaption {
    padding: 0.75rem 1rem;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .empty {
    background: var(--bg-soft);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    padding: 2.5rem;
    text-align: center;
  }

  .empty p {
    margin: 0 0 0.75rem;
  }

  .empty p:first-child {
    font-size: 1.2rem;
    font-weight: 600;
  }

  .empty-hint {
    color: var(--muted);
    max-width: 40rem;
    margin: 0 auto 1rem;
    font-size: 0.95rem;
    line-height: 1.7;
  }
</style>
