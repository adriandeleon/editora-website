---
import Layout from "./Layout.astro";
---

<Layout
  title="What's New — Editora"
  description="Everything recently shipped in Editora, straight from the changelog."
>
  <main class="page doc">
    <h1>What's New</h1>
    <p class="lead">
      Everything recently shipped, straight from the changelog. For curated
      announcements and deep-dives, see <a href="/news">News</a>.
    </p>
    <slot />
  </main>
</Layout>

<style>
  .page {
    max-width: 52rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 3rem;
  }
  h1 {
    font-size: 2.4rem;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .lead {
    color: var(--muted);
    margin: 0 0 1rem;
  }
</style>
