---
import { version, repo } from "../lib/editora";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Editora — a keyboard-driven programmer's text editor",
  description = "Editora is a fast, keyboard-driven, cross-platform programmer's text editor built with JDK 25 and JavaFX. Every action is a command, reachable by an Emacs-style keymap or a fuzzy palette.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
const url = (p: string) => `${base}/${p}`.replace(/\/{2,}/g, "/");

const nav = [
  { href: url(""), label: "Home" },
  { href: url("keybindings"), label: "Keybindings" },
  { href: url("screenshots"), label: "Screenshots" },
  { href: repo, label: "GitHub" },
];

// Highlight the active top-level page.
const path = Astro.url.pathname.replace(/\/$/, "");
const isActive = (href: string) => {
  const h = href.replace(/\/$/, "");
  if (h === url("").replace(/\/$/, "")) return path === h;
  return path.startsWith(h) && h.startsWith(base);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href={url("favicon.png")} />
    <script is:inline>
      // Apply the saved theme before paint to avoid a flash of the default.
      (function () {
        try {
          var t = localStorage.getItem("editora-theme");
          if (t && t !== "primer-dark")
            document.documentElement.dataset.theme = t;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-nav">
      <div class="nav-inner">
        <a class="brand" href={url("")}>
          <img src={url("editora-icon.svg")} alt="" width="26" height="26" />
          <span>Editora</span>
          <span class="version">v{version}</span>
        </a>
        <nav class="nav-links">
          {
            nav.map((item) => (
              <a href={item.href} class={isActive(item.href) ? "active" : ""}>
                {item.label}
              </a>
            ))
          }
          <label class="theme-picker" title="Editor theme">
            <span class="sr-only">Theme</span>
            <select id="theme-select" aria-label="Editor theme">
              <option value="primer-dark">Primer Dark</option>
              <option value="primer-light">Primer Light</option>
              <option value="dracula">Dracula</option>
              <option value="nord">Nord</option>
              <option value="cupertino-dark">Cupertino Dark</option>
              <option value="islands-dark">Islands Dark</option>
            </select>
          </label>
        </nav>
      </div>
    </header>

    <script is:inline>
      // Sync the picker with the active theme and persist changes.
      (function () {
        var sel = document.getElementById("theme-select");
        if (!sel) return;
        var current = document.documentElement.dataset.theme || "primer-dark";
        sel.value = current;
        sel.addEventListener("change", function () {
          var t = sel.value;
          if (t === "primer-dark") delete document.documentElement.dataset.theme;
          else document.documentElement.dataset.theme = t;
          try {
            localStorage.setItem("editora-theme", t);
          } catch (e) {}
        });
      })();
    </script>

    <slot />

    <footer class="footer">
      <p>
        Editora v{version} — open source.
        <a href={repo}>Source on GitHub</a> ·
        <a href={`${repo}/issues`}>Report an issue</a>
      </p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Palette mirrors Editora's "Primer Dark" editor theme
       (src/main/resources/com/editora/styles/editor-themes/primer-dark.css),
       the GitHub-dark palette AtlantaFX Primer Dark uses. */
    --bg: #0d1117; /* .editor-area background */
    --bg-soft: #161b22; /* line-number gutter background */
    --border: #30363d;
    --border-soft: #21262d; /* minimap border */
    --text: #c9d1d9; /* .editor-area .text fill */
    --muted: #8b949e; /* comment fill */
    --faint: #6e7681; /* line-number text */
    --accent: #58a6ff; /* link / fold-chevron:hover */
    --accent-soft: rgba(31, 111, 235, 0.12); /* selection #1f6feb */
    --on-accent: #06101f; /* readable text on an accent fill */
    --bookmark: #f2a65c; /* bookmark gutter marker */

    /* Syntax token colors, straight from primer-dark.css. */
    --tok-keyword: #ff7b72;
    --tok-string: #a5d6ff;
    --tok-comment: #8b949e;
    --tok-number: #79c0ff;
    --tok-function: #d2a8ff;
    --tok-type: #ffa657;

    --radius: 12px;
    --maxw: 980px;
    --mono: "JetBrains Mono", "Cascadia Code", "Fira Code", ui-monospace,
      SFMono-Regular, Menlo, Consolas, monospace;
    --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
      Arial, sans-serif;
  }

  /* Theme overrides — each mirrors an Editora editor theme under
     src/main/resources/com/editora/styles/editor-themes/. :root above is the
     Primer Dark default, so only the non-default themes need a block. */
  [data-theme="primer-light"] {
    color-scheme: light;
    --bg: #ffffff;
    --bg-soft: #f6f8fa;
    --border: #d0d7de;
    --border-soft: #eaeef2;
    --text: #24292f;
    --muted: #6e7781;
    --faint: #8c959f;
    --accent: #0969da;
    --accent-soft: rgba(9, 105, 218, 0.1);
    --on-accent: #ffffff;
    --bookmark: #d29922;
    --tok-keyword: #cf222e;
    --tok-string: #0a3069;
    --tok-comment: #6e7781;
    --tok-number: #0550ae;
    --tok-function: #8250df;
    --tok-type: #953800;
  }

  [data-theme="dracula"] {
    --bg: #282a36;
    --bg-soft: #21222c;
    --border: #44475a;
    --border-soft: #191a21;
    --text: #f8f8f2;
    --muted: #6272a4;
    --faint: #6272a4;
    --accent: #bd93f9;
    --accent-soft: rgba(189, 147, 249, 0.15);
    --on-accent: #21222c;
    --bookmark: #f2a65c;
    --tok-keyword: #ff79c6;
    --tok-string: #f1fa8c;
    --tok-comment: #6272a4;
    --tok-number: #bd93f9;
    --tok-function: #50fa7b;
    --tok-type: #8be9fd;
  }

  [data-theme="nord"] {
    --bg: #2e3440;
    --bg-soft: #353c4a;
    --border: #434c5e;
    --border-soft: #3b4252;
    --text: #d8dee9;
    --muted: #7b88a1;
    --faint: #6c7689;
    --accent: #88c0d0;
    --accent-soft: rgba(136, 192, 208, 0.15);
    --on-accent: #2e3440;
    --bookmark: #f2a65c;
    --tok-keyword: #81a1c1;
    --tok-string: #a3be8c;
    --tok-comment: #7b88a1;
    --tok-number: #b48ead;
    --tok-function: #88c0d0;
    --tok-type: #8fbcbb;
  }

  [data-theme="cupertino-dark"] {
    --bg: #1e1e1e;
    --bg-soft: #262626;
    --border: #3a3a3c;
    --border-soft: #2c2c2e;
    --text: #dfdfe0;
    --muted: #6c7986;
    --faint: #6f6f73;
    --accent: #0a84ff;
    --accent-soft: rgba(10, 132, 255, 0.15);
    --on-accent: #ffffff;
    --bookmark: #f2a65c;
    --tok-keyword: #fc5fa3;
    --tok-string: #fc6a5d;
    --tok-comment: #6c7986;
    --tok-number: #d0bf69;
    --tok-function: #67b7a4;
    --tok-type: #5dd8ff;
  }

  [data-theme="islands-dark"] {
    --bg: #191a1c;
    --bg-soft: #1f2024;
    --border: #323438;
    --border-soft: #2b2d30;
    --text: #bcbec4;
    --muted: #7a7e85;
    --faint: #4b5059;
    --accent: #56a8f5;
    --accent-soft: rgba(86, 168, 245, 0.15);
    --on-accent: #ffffff;
    --bookmark: #f2a65c;
    --tok-keyword: #cf8e6d;
    --tok-string: #6aab73;
    --tok-comment: #7a7e85;
    --tok-number: #2aacb8;
    --tok-function: #56a8f5;
    --tok-type: #d5b778;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    transition:
      background 0.2s ease,
      color 0.2s ease;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  code,
  kbd {
    font-family: var(--mono);
    font-size: 0.875em;
  }

  /* Inline code reads like a token on the editor surface. */
  :not(pre) > code {
    background: var(--bg-soft);
    border: 1px solid var(--border-soft);
    border-radius: 6px;
    padding: 0.1em 0.4em;
    color: var(--tok-string);
  }

  kbd {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-bottom-width: 2px;
    border-radius: 6px;
    padding: 0.1em 0.45em;
    color: var(--text);
    white-space: nowrap;
  }

  /* Syntax tokens for hand-highlighted code blocks (Primer Dark palette). */
  .tok-comment {
    color: var(--tok-comment);
    font-style: italic;
  }
  .tok-keyword {
    color: var(--tok-keyword);
  }
  .tok-string {
    color: var(--tok-string);
  }
  .tok-flag {
    color: var(--tok-type);
  }

  /* --- shared chrome --- */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(13, 17, 23, 0.8);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0.85rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    color: var(--text);
    font-size: 1.05rem;
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand .version {
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.05rem 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.95rem;
  }

  .nav-links a {
    color: var(--muted);
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
    text-decoration: none;
  }

  .theme-picker select {
    appearance: none;
    -webkit-appearance: none;
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--text);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 1.9rem 0.3rem 0.8rem;
    cursor: pointer;
    /* chevron drawn with the theme's muted color */
    background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%),
      linear-gradient(135deg, var(--muted) 50%, transparent 50%);
    background-position:
      right 0.95rem center,
      right 0.65rem center;
    background-size:
      5px 5px,
      5px 5px;
    background-repeat: no-repeat;
  }

  .theme-picker select:hover {
    border-color: var(--accent);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .footer {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .nav-links {
      gap: 0.9rem;
      font-size: 0.85rem;
    }
    .brand .version {
      display: none;
    }
  }
</style>
