---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";

interface Props {
  entry: CollectionEntry<"docs">;
}
const { entry } = Astro.props;

// Build the ordered sidebar: categories in a fixed order, docs by `order`.
const CATEGORY_ORDER = ["Getting started", "Guide", "Help"];
const all = (await getCollection("docs")).sort(
  (a, b) =>
    (a.data.order ?? 100) - (b.data.order ?? 100) ||
    a.data.title.localeCompare(b.data.title),
);
const cats = [
  ...new Set([...CATEGORY_ORDER, ...all.map((d) => d.data.category)]),
].filter((c) => all.some((d) => d.data.category === c));

const href = (d: CollectionEntry<"docs">) =>
  d.id === "introduction" ? "/docs" : `/docs/${d.id}`;

// Flat order for prev/next.
const flat = cats.flatMap((c) => all.filter((d) => d.data.category === c));
const idx = flat.findIndex((d) => d.id === entry.id);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

const reference = [
  { href: "/commands", label: "Commands" },
  { href: "/keybindings", label: "Keybindings" },
  { href: "/plugins", label: "Plugins catalog" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/screenshots", label: "Screenshots" },
];

const { Content } = await render(entry);
---

<Layout
  title={`${entry.data.title} — Editora Docs`}
  description={entry.data.description ?? entry.data.title}
>
  <div class="docs-wrap">
    <aside class="docs-sidebar">
      <nav>
        {
          cats.map((c) => (
            <div class="docs-cat">
              <h3>{c}</h3>
              {all
                .filter((d) => d.data.category === c)
                .map((d) => (
                  <a
                    href={href(d)}
                    class={d.id === entry.id ? "active" : ""}
                  >
                    {d.data.title}
                  </a>
                ))}
            </div>
          ))
        }
        <div class="docs-cat">
          <h3>Reference</h3>
          {reference.map((r) => <a href={r.href}>{r.label}</a>)}
        </div>
      </nav>
    </aside>

    <article class="docs-content doc">
      <h1>{entry.data.title}</h1>
      <Content />

      <nav class="docs-pager">
        {
          prev ? (
            <a class="prev" href={href(prev)}>
              <span>← Previous</span>
              {prev.data.title}
            </a>
          ) : (
            <span />
          )
        }
        {
          next && (
            <a class="next" href={href(next)}>
              <span>Next →</span>
              {next.data.title}
            </a>
          )
        }
      </nav>
    </article>
  </div>
</Layout>

<style>
  .docs-wrap {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 2.5rem 1.25rem;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .docs-sidebar {
    position: sticky;
    top: 5rem;
  }

  .docs-cat {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .docs-cat h3 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--faint);
    margin: 0 0 0.4rem;
  }

  .docs-cat a {
    color: var(--muted);
    font-size: 0.92rem;
    padding: 0.2rem 0.6rem;
    border-radius: 6px;
    border-left: 2px solid transparent;
  }

  .docs-cat a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .docs-cat a.active {
    color: var(--text);
    background: var(--bg-soft);
    border-left-color: var(--accent);
  }

  /* the .doc prose styles come from Layout's global stylesheet */
  .docs-content {
    max-width: none;
    margin: 0;
    padding: 0;
    min-width: 0;
  }

  .docs-content h1 {
    margin-top: 0;
  }

  .docs-pager {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .docs-pager a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-weight: 600;
    background: var(--bg-soft);
  }

  .docs-pager a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .docs-pager a.next {
    text-align: right;
    margin-left: auto;
  }

  .docs-pager span {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .docs-wrap {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .docs-sidebar {
      position: static;
    }
    .docs-cat {
      margin-bottom: 1rem;
    }
  }
</style>
